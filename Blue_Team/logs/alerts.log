{"timestamp": "2026-04-17T08:31:24.807+0000", "rule_id": "19009", "severity": "INFO", "description": "CIS Benchmark for Amazon Linux 2023 Benchmark v1.0.0.: Ensure sticky bit is set on all world-writable directories.", "source_ip": "Unknown", "agent": "wazuh-agent-ad7f6ffce373", "full_alert": {"agent": {"ip": "172.23.0.2", "name": "wazuh-agent-ad7f6ffce373", "id": "001"}, "manager": {"name": "wazuh.manager"}, "data": {"sca": {"scan_id": "319070859", "check": {"result": "not applicable", "remediation": "Run the following command to set the sticky bit on all world writable directories: # df --local -P | awk '{if (NR!=1) print $6}' | xargs -I '{}' find '{}' -xdev -type d \\( -perm -0002 -a ! -perm -1000 \\) 2>/dev/null | xargs -I '{}' chmod a+t '{}'.", "reason": "Invalid path or wrong permissions to run command 'sh -c \"df --local -P 2> /dev/null | awk '{if (NR!=1) print $6}' | xargs -I '{}' find '{}' -xdev -type d \\\\( -perm -0002 -a ! -perm -1000 \\\\) 2>/dev/null\"'", "compliance": {"cis_csc_v8": "3.3,4.1", "hipaa": "164.308(a)(3)(i),164.308(a)(3)(ii)(A),164.312(a)(1)", "nist_sp_800-53": "AC-5,AC-6,CM-7(1),CM-9,SA-10", "mitre_tactics": "TA0004", "mitre_techniques": "T1548", "cis": "6.1.13", "cmmc_v2": {"0": "AC.L1-3.1.1,AC.L1-3.1.2,AC.L2-3.1.3,AC.L2-3.1.5,CM.L2-3.4.1,CM.L2-3.4.2,CM.L2-3.4.6,CM.L2-3.4.7,MP.L2-3.8.2"}, "iso_27001-2013": "A.14.2.5,A.8.1.3", "mitre_mitigations": "M1028", "pci_dss_v4": {"0": "1.1.1,1.2.1,1.2.6,1.2.7,1.3.1,1.5.1,2.1.1,2.2.1,7.1"}, "soc_2": "CC5.2,CC6.1,CC7.1,CC8.1", "pci_dss_v3": {"2": {"1": "11.5,2.2,7.1,7.1.1,7.1.2,7.1.3"}}, "cis_csc_v7": "5.1"}, "description": "Setting the sticky bit on world writable directories prevents users from deleting or renaming files in that directory that are not owned by them.", "id": "31180", "title": "Ensure sticky bit is set on all world-writable directories.", "rationale": "This feature prevents the ability to delete or rename files in world writable directories (such as /tmp ) that are owned by another user.", "command": ["sh -c \"df --local -P 2> /dev/null | awk '{if (NR!=1) print $6}' | xargs -I '{}' find '{}' -xdev -type d \\\\( -perm -0002 -a ! -perm -1000 \\\\) 2>/dev/null\""]}, "type": "check", "policy": "CIS Benchmark for Amazon Linux 2023 Benchmark v1.0.0."}}, "rule": {"cis_csc_v8": ["3.3", "4.1"], "mail": false, "level": 3, "pci_dss": ["2.2"], "tsc": ["CC7.1", "CC7.2"], "hipaa": ["164.308(a)(3)(i)", "164.308(a)(3)(ii)(A)", "164.312(a)(1)"], "nist_sp_800-53": ["AC-5", "AC-6", "CM-7(1)", "CM-9", "SA-10"], "description": "CIS Benchmark for Amazon Linux 2023 Benchmark v1.0.0.: Ensure sticky bit is set on all world-writable directories.", "groups": ["sca"], "mitre_tactics": ["TA0004"], "mitre_techniques": ["T1548"], "cis": ["6.1.13"], "iso_27001-2013": ["A.14.2.5", "A.8.1.3"], "nist_800_53": ["CM.1"], "mitre_mitigations": ["M1028"], "gdpr": ["IV_35.7.d"], "firedtimes": 2, "soc_2": ["CC5.2", "CC6.1", "CC7.1", "CC8.1"], "id": "19009", "cis_csc_v7": ["5.1"]}, "decoder": {"name": "sca"}, "input": {"type": "log"}, "@timestamp": "2026-04-17T08:31:24.807Z", "location": "sca", "id": "1776414684.1413782", "timestamp": "2026-04-17T08:31:24.807+0000"}}
