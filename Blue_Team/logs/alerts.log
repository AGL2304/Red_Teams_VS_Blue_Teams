{"timestamp": "2026-04-17T08:18:58.776+0000", "rule_id": "19008", "severity": "INFO", "description": "CIS Benchmark for Amazon Linux 2023 Benchmark v1.0.0.: Ensure default group for the root account is GID 0.", "source_ip": "Unknown", "agent": "wazuh-agent-ad7f6ffce373", "full_alert": {"agent": {"name": "wazuh-agent-ad7f6ffce373", "id": "001"}, "manager": {"name": "wazuh.manager"}, "data": {"sca": {"scan_id": "319070859", "check": {"result": "passed", "remediation": "Run the following command to set the root account default group to GID 0 : # usermod -g 0 root.", "file": ["/etc/passwd"], "compliance": {"pci_dss_v4": {"0": "1.1.1,1.2.1,1.2.6,1.2.7,1.5.1,2.1.1,2.2.1"}, "cis_csc_v8": "4.1", "soc_2": "CC7.1,CC8.1", "pci_dss_v3": {"2": {"1": "11.5,2.2"}}, "nist_sp_800-53": "CM-1,CM-2,CM-6,CM-7,IA-5", "mitre_tactics": "TA0005", "mitre_techniques": "T1548", "cis": "5.6.4", "cmmc_v2": {"0": "AC.L1-3.1.1,AC.L1-3.1.2,CM.L2-3.4.1,CM.L2-3.4.2,CM.L2-3.4.6,CM.L2-3.4.7"}, "iso_27001-2013": "A.14.2.5,A.8.1.3", "cis_csc_v7": "5.1", "mitre_mitigations": "M1026"}, "description": "The usermod command can be used to specify which group the root account belongs to. This affects permissions of files that are created by the root account.", "id": "31169", "title": "Ensure default group for the root account is GID 0.", "rationale": "Using GID 0 for the root account helps prevent root -owned files from accidentally becoming accessible to non-privileged users."}, "type": "check", "policy": "CIS Benchmark for Amazon Linux 2023 Benchmark v1.0.0."}}, "rule": {"cis_csc_v8": ["4.1"], "mail": false, "level": 3, "pci_dss": ["2.2"], "tsc": ["CC7.1", "CC7.2"], "nist_sp_800-53": ["CM-1", "CM-2", "CM-6", "CM-7", "IA-5"], "description": "CIS Benchmark for Amazon Linux 2023 Benchmark v1.0.0.: Ensure default group for the root account is GID 0.", "groups": ["sca"], "mitre_tactics": ["TA0005"], "mitre_techniques": ["T1548"], "cis": ["5.6.4"], "iso_27001-2013": ["A.14.2.5", "A.8.1.3"], "nist_800_53": ["CM.1"]